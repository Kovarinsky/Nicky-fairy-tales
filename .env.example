# ── Zkopíruj tento soubor jako .env.local a doplň skutečné klíče ──
# (.env.local je v .gitignore, takže se nikdy nezacommituje)

# Claude – generování příběhu
# https://console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini "Nano Banana" – generování ilustrací
# https://aistudio.google.com → Get API key
GEMINI_API_KEY=AIza...

# ElevenLabs – namluvení (text-to-speech)
# https://elevenlabs.io → Profile → API key
ELEVENLABS_API_KEY=...

# ── Volitelná konfigurace (rozumné defaulty jsou v kódu) ──

# Model Claude pro psaní pohádek
ANTHROPIC_MODEL=claude-opus-4-8

# Gemini model pro obrázky (Nano Banana)
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Český hlas z ElevenLabs Voice Library (Voice ID)
# Vyber hlas na https://elevenlabs.io/app/voice-library a vlož jeho ID
ELEVENLABS_VOICE_ID=
# Model TTS (multilingual_v2 umí česky; v3 je expresivnější/dražší)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
